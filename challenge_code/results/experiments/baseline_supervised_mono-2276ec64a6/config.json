{
  "EXPERIMENT": {
    "keep_monocyte_indicator": false,
    "model_family": "rsf",
    "name": "baseline_supervised_mono",
    "prune_feature": true,
    "prune_feature_threshold": 0.9,
    "random_seed": 42,
    "use_center_ohe": false,
    "use_monocyte_supervised": true
  },
  "PREPROCESSING": {
    "clip_quantiles": {
      "lower": 0.01,
      "upper": 0.99
    },
    "imputer": "iterative",
    "iterative": {
      "estimator": "RandomForest",
      "estimator_n_estimators": 70,
      "max_iter": 240,
      "random_state": 42
    },
    "knn": {
      "n_neighbors": 4
    },
    "monocyte_imputer": {
      "clip_to_wbc": true,
      "model_path": "C:\\Users\\octave.cercle\\Desktop\\Challenge_data\\challenge_code\\models\\monocyte_imputer.joblib",
      "predictors": {
        "cat": [
          "CENTER"
        ],
        "num": [
          "WBC",
          "ANC",
          "HB",
          "PLT",
          "BM_BLAST"
        ]
      },
      "preprocessing": {
        "num_imputer": "median",
        "num_scaler": "standard"
      },
      "regressor": {
        "l2_regularization": 0.0,
        "learning_rate": 0.08,
        "max_depth": null,
        "max_iter": 400,
        "random_state": 42,
        "type": "HistGradientBoostingRegressor"
      },
      "winsorize_pct": 99.5
    },
    "numeric_scaler": "robust"
  }
}